5:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Authentication Credentials:"}]," Passwords you create for the dashboard are securely hashed using bcrypt before being stored in your local database."]}],["$","li",null,{"children":[["$","strong",null,{"children":"WhatsApp Sessions:"}]," WA-AB acts as a bridge to WhatsApp Web. The session tokens (keys) necessary to maintain this connection are stored locally on your server."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communication Logs:"}]," Messages sent and received via the gateway are logged within your local database to provide you with historical data and webhook functionality."]}]]}]
6:["$","h2",null,{"className":"mt-8 text-2xl border-b pb-2","children":"3. Protecting Your Information"}]
7:["$","p",null,{"children":"While WA-AB is built with modern security practices, the ultimate safety of your data depends on your hosting environment. We strongly recommend:"}]
8:["$","ul",null,{"children":[["$","li",null,{"children":["Deploying the application behind a reverse proxy with enforced ",["$","strong",null,{"children":"SSL/TLS encryption"}]," (HTTPS)."]}],["$","li",null,{"children":"Securing the host server with firewalls and SSH key authentication."}],["$","li",null,{"children":"Keeping the underlying operating system and Node.js environment constantly updated."}]]}]
